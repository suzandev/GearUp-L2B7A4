model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(CUSTOMER)
  status       UserStatus    @default(ACTIVE)
  phone        String?       
  address      String?       
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  gearItems    GearItem[]
  rentalOrders RentalOrder[]
  reviews      Review[]
  payments     Payment[]

  @@map("users")
}
